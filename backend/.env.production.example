# ─────────────────────────────────────────────────────────────────────────────
# IBS Procurement — PRODUCTION Environment Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy sang .env rồi điền giá trị thật. KHÔNG commit .env vào git.

NODE_ENV=production

# ─── Database ────────────────────────────────────────────────────────────────
# Production PostgreSQL (self-hosted hoặc managed)
DATABASE_URL=postgresql://ibshi_prod:STRONG_DB_PASSWORD@127.0.0.1:5432/ibshi_procurement?schema=public

# ─── JWT ─────────────────────────────────────────────────────────────────────
# BẮT BUỘC: tạo secret mới bằng:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_FROM_CRYPTO_RANDOM
JWT_EXPIRES_IN=8h

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5005

# ─── CORS ────────────────────────────────────────────────────────────────────
# Production: chỉ cho phép domain thực tế, KHÔNG dùng localhost
ALLOWED_ORIGINS=https://procurement.ibshi.local,https://erp.ibshi.local

# ─── Reverse proxy ───────────────────────────────────────────────────────────
# 1 = tin vào 1 lớp proxy (Nginx). Rate limit sẽ đọc X-Forwarded-For đúng.
TRUST_PROXY=1

# ─── Upload giới hạn ─────────────────────────────────────────────────────────
# Đã cấu hình cứng trong code: 30MB/file, 20 upload/10 phút/IP

# ─── Admin init (chỉ dùng khi lần đầu chạy prisma seed) ──────────────────────
ADMIN_INIT_PASSWORD=MUST_BE_STRONG_PASSWORD_MIN_8_CHARS
