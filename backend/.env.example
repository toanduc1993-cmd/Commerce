# ─────────────────────────────────────────────────────────────────────────────
# IBS Procurement System — Environment Configuration
# QUAN TRỌNG: Đổi tất cả các giá trị mặc định trước khi deploy production!
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Development (SQLite — chỉ dùng local, 1 user):
# DATABASE_URL="file:./dev.db"
#
# Production (PostgreSQL — BẮT BUỘC khi có nhiều người dùng đồng thời):
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/ibs_procurement?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Tạo secret mạnh: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=8h

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5005

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Danh sách origin được phép, phân cách bởi dấu phẩy
ALLOWED_ORIGINS=http://localhost:3000

# ─── Upload ───────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
