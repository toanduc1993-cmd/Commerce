# ─────────────────────────────────────────────────────────────────────────────
# IBS Procurement — Docker Compose Environment
# Copy thành .env rồi điền giá trị thật. KHÔNG commit .env vào git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=ibshi
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=ibshi_procurement

# ─── Backend JWT ─────────────────────────────────────────────────────────────
# Generate bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX
JWT_EXPIRES_IN=8h

# ─── CORS ────────────────────────────────────────────────────────────────────
# Domain mà browser users sẽ truy cập vào. Nhiều domain phân cách bằng dấu phẩy.
ALLOWED_ORIGINS=https://procurement.ibshi.local

# ─── Nginx ports ─────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
