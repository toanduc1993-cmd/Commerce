# ═══════════════════════════════════════════════════════════════
# IBSHI VẬT TƯ — Root .gitignore
# ═══════════════════════════════════════════════════════════════

# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp.*

# Next.js
.next/
out/
build/
dist/

# Environment variables (keep .env.example)
.env
.env.local
.env.*.local
!.env.example

# Logs
*.log
logs/

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Test scratch files (prevent re-accumulation)
test_*.js
!tests/**
!backend/tests/**
!frontend/__tests__/**

# Patches
*.patch
*.rej
*.orig

# Archives
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Temporary HTML reports
audit_report*.html
*_dashboard.html
*_presentation.html
*_plan.html

# Database
*.sqlite
*.sqlite3
*.db
backend/pg-data/
backend/pg_data/
pg_data/
backend/*.log

# Prisma
prisma/migrations/dev.db*

# Coverage
coverage/
*.lcov

# TypeScript build info
*.tsbuildinfo

# Uploaded files
uploads/
tmp/
